+const fn structural_payload_hash(
+    gate: GateId,
+    evidence: Evidence,
+    passed: bool,
+    effect: PacketEffect,
+) -> u64 {
+    let mut h = 0x8422_2325_cbf2_9ce4u64;
+    h ^= gate as u64;
+    h = h.wrapping_mul(0x100000001b3);
+    h ^= evidence as u64;
+    h = h.wrapping_mul(0x100000001b3);
+    h ^= passed as u64;
+    h = h.wrapping_mul(0x100000001b3);
+    h ^= effect as u64;
+    h = h.wrapping_mul(0x100000001b3);
+    if h == 0 { 1 } else { h }
