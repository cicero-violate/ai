+
+    pub fn append_durable(
+        &mut self,
+        path: impl AsRef<Path>,
+        entry: PolicyEntry,
+    ) -> Result<&PolicyEntry, PolicyStoreError> {
+        if entry.version <= self.latest_version() {
+            return Err(PolicyStoreError::NonMonotonicVersion);
+        }
+        key_to_id(entry.key)?;
