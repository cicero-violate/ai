 }
+
+fn legal_phase_gate(
+    to: Phase,
+    kind: EventKind,
+    cause: Cause,
+    next: Phase,
+    fail_kind: EventKind,
+    pass_cause: Cause,
+    domain_cause: Option<Cause>,
+) -> bool {
+    (to == next && kind == EventKind::Advanced && cause == pass_cause)
+        || legal_recovery_edge(to, kind, cause, fail_kind, domain_cause)
+}
+
+fn legal_recovery_edge(
+    to: Phase,
+    kind: EventKind,
+    cause: Cause,
+    fail_kind: EventKind,
+    domain_cause: Option<Cause>,
+) -> bool {
+    if to != Phase::Recovery || kind != fail_kind {
+        return false;
+    }
+
+    matches!(cause, Cause::EvidenceMissing | Cause::GateFailed)
+        || domain_cause.map(|extra| cause == extra).unwrap_or(false)
+}
+
+fn legal_learn_target(to: Phase) -> bool {
+    matches!(
+        to,
+        Phase::Invariant
+            | Phase::Analysis
+            | Phase::Judgment
+            | Phase::Plan
+            | Phase::Execute
+            | Phase::Verify
+            | Phase::Eval
+    )
+}
