digraph kernel_with_phases {
  rankdir=LR;
  graph [
    label="AI Prototype — Kernel Only (with Phases)",
    labelloc=t,
    fontsize=20
  ];

  node [shape=box, style="rounded"];
  edge [fontsize=10];

  subgraph cluster_kernel {
    label="kernel/";
    style="rounded";

    mod    [label="kernel::mod.rs\npublic kernel surface", shape=component];
    phase  [label="phase.rs\nPhase enum"];
    gate   [label="gate.rs\nGate\nGateStatus\nEvidence"];
    packet [label="packet.rs\nPacket\nLineage\nReceipts"];
    event  [label="event.rs\nControlEvent\nSemanticDelta"];
    state  [label="state.rs\nState\nRuntimeConfig"];
  }

  // Public surface
  mod -> phase;
  mod -> gate;
  mod -> packet;
  mod -> event;
  mod -> state;

  // Kernel semantic relationships
  phase  -> event  [label="event carries from/to"];
  phase  -> state  [label="state tracks current phase"];
  gate   -> state  [label="state holds gate results"];
  packet -> state  [label="state holds packet"];
  packet -> event  [label="event records packet delta"];
  gate   -> event  [label="event records gate evidence"];
  event  -> state  [label="state evolves by event replay"];

  // Phase flow
  subgraph cluster_phase_flow {
    label="Phase progression";
    style="dashed";

    p_delta    [label="Delta"];
    p_invar    [label="Invariant"];
    p_judge    [label="Judgment"];
    p_plan     [label="Plan"];
    p_execute  [label="Execute"];
    p_verify   [label="Verify"];
    p_eval     [label="Eval"];
    p_recover  [label="Recovery"];
    p_learn    [label="Learn"];
    p_done     [label="Done"];

    p_delta   -> p_invar;
    p_invar   -> p_judge;
    p_judge   -> p_plan;
    p_plan    -> p_execute;
    p_execute -> p_verify;
    p_verify  -> p_eval;
    p_eval    -> p_done   [label="if success"];
    p_eval    -> p_recover [label="if failure"];
    p_recover -> p_execute [label="resume repaired gate"];
    p_recover -> p_learn   [label="synthesize lesson"];
    p_learn   -> p_plan    [label="retry with learned repair"];
  }

  // Link phase enum to concrete flow
  phase -> p_delta   [style=dashed];
  phase -> p_invar   [style=dashed];
  phase -> p_judge   [style=dashed];
  phase -> p_plan    [style=dashed];
  phase -> p_execute [style=dashed];
  phase -> p_verify  [style=dashed];
  phase -> p_eval    [style=dashed];
  phase -> p_recover [style=dashed];
  phase -> p_learn   [style=dashed];
  phase -> p_done    [style=dashed];

  purity [shape=note, label="kernel is pure:\nno fs\nno codec\nno recovery policy engine\nno verification engine"];
  purity -> mod [style=dashed];
}
