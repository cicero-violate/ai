+struct RepairReceipt {
+    action: RecoveryAction,
+    gate: Option<GateId>,
+    evidence: Evidence,
+}
+
+impl RepairReceipt {
+    fn for_action(action: RecoveryAction) -> Self {
+        Self {
+            action,
+            gate: action.repaired_gate(),
+            evidence: Evidence::RepairApplied,
+        }
+    }
+
+    fn verifies(self, gate: GateId) -> bool {
+        self.gate == Some(gate) && self.evidence == Evidence::RepairApplied
+    }
+}
