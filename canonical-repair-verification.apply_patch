+fn consume_verified_repair(s: &mut State, gate_id: GateId) -> bool {
+    let Some(receipt) = s.pending_repair else {
+        return false;
+    };
+
+    if !receipt.verifies(gate_id) {
+        return false;
+    }
+
+    s.gates.set_pass(gate_id);
+    s.pending_repair = None;
+    true
+}
